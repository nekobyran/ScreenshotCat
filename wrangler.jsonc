{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kacha-release",
  "compatibility_date": "2026-07-19",
  "workers_dev": false,
  "preview_urls": false,
  "assets": {
    "directory": "./website/.dist",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "routes": [
    {
      "pattern": "kacha.nkbr.cc",
      "custom_domain": true
    }
  ]
}

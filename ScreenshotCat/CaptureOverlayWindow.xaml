<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ScreenshotCat.CaptureOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ScreenshotCat Capture">
    <Grid
        x:Name="Root"
        Background="Transparent"
        KeyDown="Root_KeyDown"
        PointerPressed="Root_PointerPressed"
        PointerMoved="Root_PointerMoved"
        PointerReleased="Root_PointerReleased">
        <Image x:Name="ScreenPreview" Stretch="Fill" />

        <Canvas x:Name="DimCanvas" IsHitTestVisible="False">
            <Rectangle x:Name="TopDim" Fill="#99000000" />
            <Rectangle x:Name="LeftDim" Fill="#99000000" />
            <Rectangle x:Name="RightDim" Fill="#99000000" />
            <Rectangle x:Name="BottomDim" Fill="#99000000" />
            <Rectangle
                x:Name="SelectionBorder"
                Stroke="#FF18A0FB"
                StrokeThickness="3"
                Fill="Transparent"
                Visibility="Collapsed" />
        </Canvas>

        <Canvas x:Name="AnnotationCanvas" IsHitTestVisible="False" />

        <Border
            x:Name="ModeToolbar"
            Padding="8,6"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="12"
            Background="#DD111111"
            CornerRadius="8"
            BorderBrush="#88AAAAAA"
            BorderThickness="1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock
                    x:Name="WrapModeText"
                    VerticalAlignment="Center"
                    Text="长按窗口后可操作"
                    FontSize="12"
                    Foreground="White"
                    Opacity="0.86" />
                <Button
                    x:Name="AnnotationModeButton"
                    MinWidth="86"
                    Padding="10,4"
                    Click="AnnotationModeButton_Click"
                    Content="开启批注" />
            </StackPanel>
        </Border>

        <Border
            x:Name="SavedNotesPanel"
            Width="320"
            MaxHeight="260"
            Padding="10,8"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="12,64,12,12"
            Background="#CC111111"
            CornerRadius="8"
            BorderBrush="#88AAAAAA"
            BorderThickness="1"
            IsHitTestVisible="False"
            Visibility="Collapsed">
            <ScrollViewer
                x:Name="SavedNotesScroller"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="SavedNotesList" Spacing="8" />
            </ScrollViewer>
        </Border>

        <Border
            x:Name="NotePanel"
            Width="420"
            Padding="12"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="0"
            Background="#F5222222"
            CornerRadius="8"
            Visibility="Collapsed">
            <TextBox
                x:Name="NoteBox"
                Header="批注"
                KeyDown="NoteBox_KeyDown"
                PlaceholderText="输入批注后按 Enter 保存" />
        </Border>
    </Grid>
</Window>

<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ScreenshotCat.AttachedToolbarWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ScreenshotCat 常驻批注栏">
    <Grid x:Name="Root" Background="Transparent" RequestedTheme="Dark">
        <Grid.Resources>
            <Style x:Key="ToolbarIconButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="#E7F1F8" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>
            <LinearGradientBrush x:Key="ActionTextBrush" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Offset="0" Color="#FF59C7FF" />
                <GradientStop Offset="0.52" Color="#FF8D7CFF" />
                <GradientStop Offset="1" Color="#FFFF70C8" />
            </LinearGradientBrush>
        </Grid.Resources>

        <Grid Padding="6,0" ColumnSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Click="CloseButton_Click"
                Style="{StaticResource ToolbarIconButtonStyle}"
                ToolTipService.ToolTip="取消常驻批注窗口">
                <FontIcon FontSize="14" Glyph="&#xE711;" />
            </Button>

            <Grid
                x:Name="DragRegion"
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="#01000000"
                PointerMoved="DragRegion_PointerMoved"
                PointerPressed="DragRegion_PointerPressed"
                PointerReleased="DragRegion_PointerReleased">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="6">
                    <FontIcon
                        FontSize="13"
                        Foreground="#C7DEEE"
                        Glyph="&#xE8BD;" />
                    <TextBlock
                        x:Name="StatusText"
                        VerticalAlignment="Center"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="常驻批注" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#B7C9D6"
                        Text="拖拽移动窗口" />
                </StackPanel>
            </Grid>

            <HyperlinkButton
                Grid.Column="2"
                Height="30"
                Padding="12,0"
                Background="Transparent"
                BorderThickness="0"
                Click="AnnotateButton_Click"
                IsTabStop="False">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource ActionTextBrush}"
                    Text="批注" />
            </HyperlinkButton>
        </Grid>
    </Grid>
</Window>
